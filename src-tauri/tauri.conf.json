{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FilaMind screen",
  "version": "0.1.3",
  "identifier": "app.filamind.screen",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5274",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FilaMind screen",
        "fullscreen": true,
        "decorations": false,
        "resizable": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:7125 http://localhost:7125 ws://127.0.0.1:7125 http://127.0.0.1:7125; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "Utility",
    "shortDescription": "On-printer touch control",
    "longDescription": "FilaMind screen is a native touch control app for a Klipper / Moonraker printer's attached display.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
