{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": { "@/*": ["./src/*"] },
    "types": ["vite/client", "node"],
    "noEmit": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["env.d.ts", "src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
